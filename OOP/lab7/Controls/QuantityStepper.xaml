<UserControl x:Class="FlowerShop.Controls.QuantityStepper"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="36" Width="140">
    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="32"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="-"
                    Padding="0"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Click="DecreaseButton_Click"/>

            <TextBox x:Name="PART_Text"
                     Grid.Column="1"
                     Margin="4,0"
                     Padding="0"
                     VerticalAlignment="Center"
                     HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center"
                     Text="{Binding DisplayQuantity, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     LostFocus="PART_Text_LostFocus"
                     Foreground="Black"
                     Background="White"/>

            <Button Grid.Column="2"
                    Content="+"
                    Padding="0"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Click="IncreaseButton_Click"/>
        </Grid>
    </Border>
</UserControl>
