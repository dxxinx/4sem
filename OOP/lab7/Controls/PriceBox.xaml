<UserControl x:Class="FlowerShop.Controls.PriceBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="30" Width="120">
    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="4">
        <TextBox x:Name="PART_Text"
                 Text="{Binding DisplayPrice, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 LostFocus="PART_Text_LostFocus"
                 Foreground="Black"
                 Background="White"/>
    </Border>
</UserControl>
