<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="PrimaryBrush" Color="#9C27B0"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#7B1FA2"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#E1BEE7"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF5F5F5"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="LightCoral"/>
    <SolidColorBrush x:Key="WarningBrush" Color="Yellow"/>
</ResourceDictionary>