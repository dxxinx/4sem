<Window x:Class="FlowerShop.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить товар" Height="350" Width="300">

    <StackPanel Margin="20">

        <TextBlock Text="Название"/>
        <TextBox x:Name="NameBox"/>

        <TextBlock Text="Категория" Margin="0,10,0,0"/>
        <TextBox x:Name="CategoryBox"/>

        <TextBlock Text="Цена" Margin="0,10,0,0"/>
        <TextBox x:Name="PriceBox"/>

        <TextBlock Text="Количество" Margin="0,10,0,0"/>
        <TextBox x:Name="QuantityBox"/>

        <Button Content="Добавить"
                Margin="0,20,0,0"
                Click="Add_Click"/>

    </StackPanel>

</Window>